# ==============================================================
# VendaFácil — Configurações de Ambiente
# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA envie este arquivo para o Git (adicione .env ao .gitignore)
# ==============================================================

# --------------------------------------------------------------
# SUPABASE — Banco de Dados
# Obtenha em: https://app.supabase.com > Projeto > Settings > API
# --------------------------------------------------------------
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=sua_chave_anonima_supabase
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_supabase

# --------------------------------------------------------------
# GOOGLE OAUTH — Login com Google
# Obtenha em: https://console.cloud.google.com > APIs & Services > Credentials
# URL de callback: https://seudominio.com/auth/callback
# --------------------------------------------------------------
GOOGLE_CLIENT_ID=seu_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback

# --------------------------------------------------------------
# STRIPE — Pagamentos com Cartão
# Obtenha em: https://dashboard.stripe.com/apikeys
# Deixe em branco para desabilitar (aparecerá como "Indisponível")
# --------------------------------------------------------------
STRIPE_PUBLIC_KEY=pk_test_sua_chave_publica_stripe
STRIPE_SECRET_KEY=sk_test_sua_chave_secreta_stripe
STRIPE_WEBHOOK_SECRET=whsec_seu_webhook_secret

# --------------------------------------------------------------
# PIX VIA IMAP — Confirmação de Pagamento Pix por E-mail
# Configure o e-mail que recebe notificações do seu banco (Pix)
# Deixe em branco para desabilitar (aparecerá como "Indisponível")
# Exemplo Itaú: imap.itau.com.br:993
# Exemplo Bradesco: imap.bradesco.com.br:993
# Exemplo Nubank: imap.nubank.com.br:993
# --------------------------------------------------------------
IMAP_HOST=imap.seubanco.com.br
IMAP_PORT=993
IMAP_USER=seu_email_pix@seubanco.com.br
IMAP_PASSWORD=sua_senha_email_pix
IMAP_TLS=true
IMAP_MAILBOX=INBOX
# Texto que aparece nos e-mails de confirmação Pix do seu banco:
IMAP_PIX_SUBJECT_FILTER=Pix recebido
# Chave Pix para exibir ao comprador (CPF, CNPJ, e-mail ou celular):
PIX_CHAVE=81991610473
PIX_BENEFICIARIO=VendaFácil LTDA
PIX_CIDADE=Recife

# --------------------------------------------------------------
# CONTATO & APP
# --------------------------------------------------------------
WHATSAPP_NUMBER=5581991610473
APP_URL=http://localhost:3000
APP_NAME=VendaFácil
APP_SECRET=uma_string_secreta_para_sessoes_jwt

# --------------------------------------------------------------
# NODE / SERVIDOR (se usar backend Node.js)
# --------------------------------------------------------------
PORT=3000
NODE_ENV=development
